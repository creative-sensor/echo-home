path_dict=("mcfunction" "$HOME/echo-home/workstation/macos/.function"
           "rtfunction" "$HOME/echo-home/.function"
           "node" $LOCAL_BIN/node
           "yson" $HOME/echo-home/codev/yson/.function
           "cmake" $LOCAL_BIN/cmake/bin
           "gnupg" $HOME/.local/bin/gnupg/bin:$HOME/.local/bin/pinentry/bin
           "gettext" $LOCAL_BIN/gettext/bin
           "gmlama" $LOCAL_BIN/gmlama)


for key in "${!path_dict[@]}"; do
  PATH+=":${path_dict[$key]}"
done

unset path_dict
