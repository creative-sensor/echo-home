tar -xf $ARTIFACT_DIR/$name-$ARTIFACT_VERSION.tar.gz
cd llama.cpp-${ARTIFACT_VERSION}
mkdir -p build
mkdir -p $LOCAL_BIN/gmlama/${ARTIFACT_VERSION}

cmake -B build \
  -DBUILD_SHARED_LIBS=ON \
  -DCMAKE_INSTALL_PREFIX=$LOCAL_BIN/gmlama/${ARTIFACT_VERSION} \
  -DCMAKE_INSTALL_BINDIR="." \
  -DCMAKE_INSTALL_LIBDIR="." \
  -DCMAKE_INSTALL_RPATH='.' \
  -DCMAKE_BUILD_WITH_INSTALL_RPATH=ON


cd build && make install
cd ../..
  
rm -r llama.cpp-${ARTIFACT_VERSION}
