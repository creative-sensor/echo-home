#!/usr/bin/env bash
set -x
# ---- |EXT ----
VARSET_EXT=$1
# ---- |DEFAULT ----

# ---- |OVERRIDE ----
source .properd/VARSET
test -n "$VARSET_EXT" && source $VARSET_EXT

# ---- |MAIN ----

# 1. Run the container in detached mode to perform initial setup
# We use -d so it runs in the background. 
# We use --name to make it easy to reference.
CONTAINER_NAME="desktop-commander"
IMAGE_NAME="mcp/desktop-commander"

# Remove existing container if it exists to avoid name conflicts
#docker rm -f $CONTAINER_NAME >/dev/null 2>&1

docker run -d --name $CONTAINER_NAME -v $HOME/tmp:/home/$(whoami) $IMAGE_NAME

# 2. Wait for the setup to complete. 
# Since we don't know exactly how long setup takes, we wait for the container 
# to be "ready" or simply sleep. For this script, we will sleep for 15 seconds.
# You can adjust this value.
sleep 15

# 3. Use mcp-proxy to attach to the container using its ID/Name
MSYS_NO_PATHCONV=1 uvx mcp-proxy --transport streamablehttp --allow-origin '*' --port 10001 -- docker start -i $CONTAINER_NAME
