" Function to extract data from the current line in the table and invoke port-remote
function! PortRemoteFromTable()
    " Get the current line
    let current_line = getline('.')
    
    " Execute awk using the external script file to parse the Markdown table row.
    " The script reads from stdin, which is piped from the current line.
    let awk_command = 'echo -e "' . current_line . '" | awk -f ~/echo-home/awk_script.awk'
    
    " Execute awk directly on the line
    let output = system(awk_command)
    
    " Split the output string into parts based on spaces
    let parts = split(output, ' ')
    echo parts 
    " We expect 4 meaningful values (SSH_HOST, S, IP, D)
    if len(parts) >= 4
        " Assuming the order is: SSH_HOST, S, IP, D

        let ssh_host = parts[0]
        let s_val = parts[1]
        let ip_val = parts[2]
        let d_val = parts[3]
        "let l:cmd = ['port-remote' ,'192.168.0.12', '8081', '127.0.0.1', '8081']
        let l:cmd = ['port-remote' , ssh_host, s_val, ip_val, d_val]
        let l:opts = {}
        call jobstart(l:cmd, l:opts)
    else
        echo "Error: Could not parse table row data correctly using awk. Output received: " . output
    endif
endfunction

" Map 'ptrm' to invoke the function
nnoremap ptrm :call VimPage_ptrm()<CR>
nnoremap ptrmo :call PortRemoteFromTable()<CR>
nnoremap ptrmc :call PortRemoteFromTable()<CR>

" Function to load MIMD view, opening ptrm.md first
function! VimPage_ptrm()
    tabnew | e | source .vim/pages/ptrm.md
endfunction
