" Function to extract data from the current line in the table and invoke port-remote
function! PortRemoteFromTable()
    " Get the current line
    let current_line = getline('.')
    
    " Execute awk using the external script file to parse the Markdown table row.
    " The script reads from stdin, which is piped from the current line.
    let awk_command = 'echo -e "' . current_line . '" | awk -f ~/echo-home/.vim/mimd/ptrm/args.awk'
    
    " Execute awk directly on the line
    let output = system(awk_command)
    
    " Split the output string into parts based on spaces
    let parts = split(output, ' ')
    echo parts 
    " We expect 4 meaningful values (SSH_HOST, S, IP, D)
    if len(parts) >= 4
        " Assuming the order is: SSH_HOST, S, IP, D

        let ssh_host = parts[0]
        let s_val = parts[1]
        let ip_val = parts[2]
        let d_val = parts[3]
        "let l:cmd = ['port-remote' ,'192.168.0.12', '8081', '127.0.0.1', '8081']
        "let l:cmd = ['port-remote' , ssh_host, s_val, ip_val, d_val]
        let l:cmd = ['sh','~/echo-home/.function/port-remote' , ssh_host, s_val, ip_val, d_val]
        let l:opts = {}
        call jobstart(l:cmd, l:opts)

        sleep 3
        let curl_check_cmd = 'curl -v -I http://localhost:'.  s_val  .' 2>&1  | grep -o -m 1 Connected'
        let l:status_output = system(curl_check_cmd)
        let l:connected = match(l:status_output, 'Connected')
        let l:status_icon = l:connected ? '❌' : '✅'
        execute "normal! A" . l:status_icon

    else
        echo "Error: Could not parse table row data correctly using awk. Output received: " . output
    endif
endfunction

" Function to check port status using curl and display indicator
function! CheckPortStatusFromTable()
    " Get the current line
    let l:current_line = getline('.')
    
    " Execute awk using the external script file to parse the Markdown table row.
    " The script reads from stdin, which is piped from the current line.
    let awk_command = 'echo -e "' . current_line . '" | awk -f ~/echo-home/.vim/mimd/ptrm/args.awk'
    
    " Execute awk directly on the line
    let output = system(awk_command)
    
    " Split the output string into parts based on spaces
    let parts = split(output, ' ')
    
    if len(parts) >= 4
        " Assuming the order is: SSH_HOST, S, IP, D
        let ssh_host = parts[0]
        let l:s_val = parts[1] " This is the port we need to check
        let ip_val = parts[2]
        let d_val = parts[3]
        
        let curl_check_cmd = 'curl -v -I http://localhost:'.  l:s_val  .' 2>&1  | grep -o -m 1 Connected'
        let l:status_output = system(curl_check_cmd)
        let l:connected = match(l:status_output, 'Connected')
        let l:status_icon = l:connected ? '❌' : '✅'
        execute "normal! A" . l:status_icon
    else
        echo "Error: Could not parse table row data correctly using awk. Output received: " . output
    endif
endfunction

" Map 'ptrm' to invoke the function
nnoremap ptrm :call VimPage_ptrm()<CR>
nnoremap ptrmo :call PortRemoteFromTable()<CR>
nnoremap ptrmc :call CheckPortStatusFromTable()<CR>



function! VimPage_ptrm()
    " Construct the paths
    let l:host_file = expand('~/echo-home/.vim/pages/' . g:hostname . '.ptrm.md')
    let l:default_file = expand('~/echo-home/.vim/pages/ptrm.md')

    " Determine which file to use
    if filereadable(l:host_file)
        let l:default_file = l:host_file
    endif
    exec 'tabnew '.l:default_file
endfunction
