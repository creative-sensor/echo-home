"-------- [LMSH] --------
function! VimPage_lmsh()
    let l:host_file = expand('~/echo-home/.vim/pages/' . g:hostname . '.lmsh.md')
    let l:default_file = expand('~/echo-home/.vim/pages/lmsh.md')

    if filereadable(l:host_file)
        let l:default_file = l:host_file
    endif
    exec 'vsplit '.l:default_file
endfunction

function! Lmsh_activate(agent_line)
    " Get the current line
    let l:current_line = a:agent_line
    
    " Execute awk using the external script file to parse the Markdown table row.
    let l:awk_command = 'echo -e "' . l:current_line . '" | awk -f ~/echo-home/.vim/mimd/lmsh/args.awk'
    " Trim the output to remove trailing newlines from the system call
    let l:awk_out = trim(system(l:awk_command))
    
    " Split the output string into parts (parts[0] = script, parts[1] = cmd/args, parts[2] = port)
    let l:parts = split(l:awk_out, ' ')
    
    if len(l:parts) >= 3
        let l:script_dir = expand('~/echo-home/workstation/lmstudio/promptia/')
        let l:script_name = l:parts[0]
        let l:cmd_args = l:parts[1]
        let l:port = l:parts[2]
        
        let l:port_check = system('curl -s http:/localhost:'.l:port.'/models | grep -o models')
        let l:cmd = 'cd ' . l:script_dir . ' && ./' . l:script_name . ' --port ' . l:port
        if l:port_check =~ 'models'
            echo "Skipping gml8w -- " . l:port . " is already in use."
            exec 'term ' . l:cmd
        else
            " Construct the command: cd to directory, run script with args and port
            " We include the command/args as part of the execution logic
            exec 'term gml8w ' . l:cmd_args
            exec 'split | term sleep 10;' . l:cmd
        endif
    else
        echo "Error: Could not parse table row data correctly using awk. Expected 3 parts."
    endif
endfunction

map lmsh : call VimPage_lmsh()<CR>
map lmsha : call Lmsh_activate(getline('.'))<CR>
map lmsh0 : vsplit<CR>:call Lmsh_activate('\|sh7t.py\|14\|8900\|')<CR>
map lmsh1 : vsplit<CR>:call Lmsh_activate('\|python-cliner.py\|15\|8083\|')<CR>
