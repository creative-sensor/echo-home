#!/usr/bin/env python3
import argparse
import os
import sys
import chromadb

# ANSI Color Codes for terminal highlighting
BLUE = "\033[94m"         # Bright blue text
# BLUE = "\033[44m\033[97m" # Uncomment this instead for a solid blue background
RESET = "\033[0m"         # Reset color

def inspect_db(db_path, include_embeddings=False):
    if not os.path.exists(db_path):
        print(f"Error: The directory '{db_path}' does not exist.")
        sys.exit(1)
        
    print(f"Connecting to ChromaDB at: {db_path}\n")
    
    try:
        client = chromadb.PersistentClient(path=db_path)
    except Exception as e:
        print(f"Error connecting to database: {e}")
        sys.exit(1)

    collections = client.list_collections()
    
    if not collections:
        print("No collections found in the database.")
        return

    print(f"Found {len(collections)} collection(s):\n")

    fetch_fields = ["documents", "metadatas"]
    if include_embeddings:
        fetch_fields.append("embeddings")

    for col in collections:
        print(f"=== Collection: {col.name} ===")
        total_records = col.count()
        print(f"Total records: {total_records}")
        
        if total_records > 0:
            data = col.get(include=fetch_fields)
            
            for i in range(len(data["ids"])):
                doc_id = data["ids"][i]
                metadata = data["metadatas"][i] if data["metadatas"] else None
                
                raw_doc = data["documents"][i] if data["documents"] else None
                if raw_doc:
                    lines = raw_doc.splitlines()
                    document = lines[0] + (" ... [truncated]" if len(lines) > 1 else "")
                else:
                    document = None
                
                # Highlight the entire ID line in blue
                print(f"\n{BLUE}  [{i+1}] ID:       {doc_id}{RESET}")
                print(f"      Document: {document}")
                print(f"      Metadata: {metadata}")
                
                if include_embeddings and "embeddings" in data and data["embeddings"] is not None:
                    vec = data["embeddings"][i]
                    print(f"      Embedding: [{vec[0]:.4f}, {vec[1]:.4f}, ... ] (Length: {len(vec)})")
                
        print("\n" + "-" * 50 + "\n")

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="View and inspect data in a ChromaDB database.")
    
    parser.add_argument(
        "--path", 
        "-p", 
        type=str, 
        default="./chroma_db", 
        help="Path to the ChromaDB database folder (default: ./chroma_db)"
    )
    
    parser.add_argument(
        "--embeddings", 
        "-e", 
        action="store_true", 
        help="Include vector embeddings in the output"
    )
    
    args = parser.parse_args()
    inspect_db(args.path, args.embeddings)
