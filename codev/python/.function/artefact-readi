#!/bin/bash -x 
NAME=${1:-all}
ARTIFACT_DIR=./artefacts
ARTIFACT_YSON=.properd/artefacts.yaml

function ready (){
	local name=$1
	local ARTIFACT_VERSION=$(cat $ARTIFACT_YSON | yq -r ".${name}[0]")
	local PYTHON_VERSION=$(cat $ARTIFACT_YSON | yq -r ".${name}[1].python")
	local IS_UV=$(cat $ARTIFACT_YSON | yq -r ".${name}[1].uv")

  rm -rf $ARTIFACT_DIR/$name
  test -r $ARTIFACT_DIR/.function/ready/$name && source $ARTIFACT_DIR/.function/ready/$name && return

	if [[ "$IS_UV" == "true" ]]; then
		# For uv packages, we do nothing as per requirement
		return
	fi

	# Handle pip package
	if [[ "$PYTHON_VERSION" != "null" ]]; then
		local TARGET_DIR="$LOCAL_BIN/python/$PYTHON_VERSION/$name"
		mkdir -p "$TARGET_DIR"
		# Find whl files in the artifact directory for this package
		# Note: artifacts are stored in $ARTIFACT_DIR/$name/ after extraction or download
		# Based on geti, they are in $ARTIFACT_DIR/$name
		find "$ARTIFACT_DIR/$name" -name "*.whl" | xargs pip install --target "$TARGET_DIR"
	fi

  tar xf $ARTIFACT_DIR/$name-$ARTIFACT_VERSION${OS}.tar.gz -C $ARTIFACT_DIR
  ln -sf $(readlink -f $ARTIFACT_DIR/$name/bin/*) $LOCAL_BIN/$name

}

mkdir -p $ARTIFACT_DIR
if [[ "$NAME" =~ "all" ]] ; then
	LIST=$(cat $ARTIFACT_YSON | yq 'keys' | awk -F ' ' '{print $2}')
	for i in $LIST ; do
		ready $i
	done
	exit
fi
ready $NAME
