#!/usr/bin/env python
import sys
import os
import requests
import subprocess
import argparse
import json

def get_command_from_llm(prompt, server_url):
    """
    Sends the prompt to the llama.cpp server and expects a shell command in return.
    """
    system_prompt = (
        "You are a shell command generator. "
        "The user will provide a natural language request. "
        "You must respond ONLY with the single shell command that fulfills the request. "
        "Do not include explanations, markdown code blocks, or any other text. "
        "Just the command."
    )

    # Use environment variable if set, otherwise fall back to the provided server_url
    effective_url = os.getenv('LLM_URL', server_url)

    payload = {
        "messages": [
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": prompt}
        ],
        "temperature": 0.0  # Keep it deterministic
    }

    try:
        response = requests.post(f"{effective_url}/chat/completions", json=payload)
        response.raise_for_status()
        result = response.json()
        command = result['choices'][0]['message']['content'].strip()
        
        # Clean up potential markdown formatting if the LLM ignores instructions
        if command.startswith("```"):
            lines = command.splitlines()
            if len(lines) > 2:
                # Remove first line (```bash or ```) and last line (```)
                command = "\n".join(lines[1:-1]).strip()
            else:
                command = command.replace("```", "").strip()
        
        return command
    except Exception as e:
        print(f"Error communicating with LLM server: {e}")
        sys.exit(1)

def run_command(command):
    """
    Executes the command in the local shell and captures output.
    Returns (returncode, stdout, stderr).
    """
    try:
        result = subprocess.run(command, shell=True, capture_output=True, text=True)
        return result.returncode, result.stdout, result.stderr
    except Exception as e:
        return -1, "", str(e)

def execute_command(command, prompt, url, interactive=True):
    """
    Executes the command in the local shell.
    If interactive=True, asks the user for confirmation and retries once on failure.
    If interactive=False, retries once automatically without user prompts.
    """
    if not command:
        print("No command received.")
        return

    if interactive:
        print(f"\n[PROPOSED COMMAND]: {command}")
        confirm = input("Execute this command? (y/N): ").lower()

        if confirm == 'y':
            rc, out, err = run_command(command)
            if rc == 0:
                print(out)
            else:
                print(f"Command failed with exit code {rc}.")
                print(f"Error output: {err}")
                print("Getting a new command from the LLM...")
                new_command = get_command_from_llm(prompt, url)
                print(f"\n[NEW PROPOSED COMMAND]: {new_command}")
                confirm2 = input("Execute this new command? (y/N): ").lower()
                if confirm2 == 'y':
                    rc2, out2, err2 = run_command(new_command)
                    if rc2 == 0:
                        print(out2)
                    else:
                        print(f"New command also failed with exit code {rc2}.")
                        print(f"Error output: {err2}")
                        sys.exit(rc2)
                else:
                    print("Execution cancelled.")
        else:
            print("Execution cancelled.")
    else:
        # Non-interactive mode: retry once on failure
        for attempt in range(2):
            rc, out, err = run_command(command)
            if rc == 0:
                print(out)
                return
            if attempt == 0:
                print("Command failed, retrying once...")
                new_command = get_command_from_llm(prompt, url)
                command = new_command
            else:
                break
        # If we get here, both attempts failed
        print(f"Command failed after retries. Exit code {rc}.")
        print(f"Error output: {err}")

def main():
    parser = argparse.ArgumentParser(description="Submit prompt to llama.cpp and execute the resulting command.")
    parser.add_argument("prompt", type=str, help="The natural language request for the LLM.")
    parser.add_argument("--url", type=str, default="http://localhost:8080/v1", help="The base URL of the llama.cpp server (default: http://localhost:8080/v1)")
    parser.add_argument("--json", action='store_true', help="Generate JSON output instead of interactive execution")

    args = parser.parse_args()

    command = get_command_from_llm(args.prompt, args.url)

    if args.json:
        # Non-interactive mode with automatic retry
        final_command, output = execute_command(command, args.prompt, args.url, interactive=False)
        result = {"command": final_command, "execution_output": output}
        print(json.dumps(result))
    else:
        # Interactive mode (original behavior)
        execute_command(command, args.prompt, args.url, interactive=True)

if __name__ == "__main__":
    main()
