" Function to extract data from the current line in the table and invoke port-remote
function! PortRemoteFromTable()
    " Get the current line
    let current_line = getline('.')
    
    " Use awk to parse the Markdown table row, splitting by '|' and trimming whitespace from relevant fields.
    " The expected fields are: SSH_HOST ($2), S ($3), IP ($4), D ($5).
    " We embed the logic directly into the system call for robustness.
    " The awk script trims fields 2 through 5 and prints them separated by spaces.
    let awk_command = 'echo -e "' . current_line . '" | awk -F"|" "{ gsub(/^ *| *$/, \"\", $2); gsub(/^ *| *$/, \"\", $3); gsub(/^ *| *$/, \"\", $4); gsub(/^ *| *$/, \"\", $5); print $2, $3, $4, $5 }"'
    
    " Execute awk directly on the line
    let output = system(awk_command)
    
    " Split the output string into parts based on spaces
    let parts = split(output, ' ')
    
    " We expect 4 meaningful values (SSH_HOST, S, IP, D)
    if len(parts) >= 4
        " Assuming the order is: SSH_HOST, S, IP, D
        let ssh_host = parts[1]
        let s_val = parts[2]
        let ip_val = parts[3]
        let d_val = parts[4]
        
        " Execute the port-remote shell script
        execute '! port-remote ' . ssh_host . ' ' . s_val . ' ' . ip_val . ' ' . d_val
    else
        echo "Error: Could not parse table row data correctly using awk. Output received: " . output
    endif
endfunction

" Map 'ptrm' to invoke the function
nnoremap <leader>ptrm :call PortRemoteFromTable()<CR>

" Function to load MIMD view, opening ptrm.md first
function! VimPage_mimd()
    " Open ptrm.md in a new vertical split to show the UI
    vsplit | e | source .vim/pages/ptrm.md
    
    " In the other split, list the mini modules
    execute 'split | enew | r!cd ~/echo-home/.vim/mimd; find . -type f'
    execute "0put ='### Mini Modules KM[mimds]'"
    execute "1put ='--------'"
    execute "$put ='' | $put ='--------'"
    execute 'set ft=markdown'
endfunction
