#!/bin/bash 
# Determine the project root (the parent directory of this script's directory)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

NAME=${1:-all}
ARTIFACT_DIR="$PROJECT_ROOT/artefacts"
ARTIFACT_YSON="$PROJECT_ROOT/.properd/artefacts.yaml"
CHECKSUM_FILE="$PROJECT_ROOT/.properd/artefact.sha256sum"

function download (){
	local name=$1
	local ARTIFACT_VERSION=$(cat "$ARTIFACT_YSON" | yq -r ".${name}[0]")
	local ARTIFACT_URL=$(cat "$ARTIFACT_YSON" | yq -r ".${name}[1]")
	local ARTIFACT_SUFFIX=$(cat "$ARTIFACT_YSON" | yq -r ".${name}[2].suffix")
	[[ "$ARTIFACT_SUFFIX" =~ "null" ]] && ARTIFACT_SUFFIX=dmg
	
	local FILENAME="$ARTIFACT_DIR/$name-$ARTIFACT_VERSION.$ARTIFACT_SUFFIX"
	
	set -x
	curl -s -L -o "$FILENAME" "$ARTIFACT_URL"
	set +x

	# Verify checksum if the file exists in the checksum registry
	if [ -f "$CHECKSUM_FILE" ]; then
		echo "Verifying checksum for $FILENAME..."
		
		# We run sha256sum from the root. 
		# We extract the expected hash for this specific file from the checksum file
		# We use grep on the filename part to find the correct line
		local EXPECTED_HASH=$(grep "$name-$ARTIFACT_VERSION.$ARTIFACT_SUFFIX" "$CHECKSUM_FILE" | awk '{print $1}')
		
		if [ -z "$EXPECTED_HASH" ]; then
			echo "Warning: No checksum entry found for $FILENAME in $CHECKSUM_FILE"
			return 0
		fi

		local ACTUAL_HASH=$(sha256sum "$FILENAME" | awk '{print $1}')

		if [ "$EXPECTED_HASH" == "$ACTUAL_HASH" ]; then
			echo "Checksum verified successfully."
		else
			echo "ERROR: Checksum verification failed for $FILENAME"
			echo "Expected: $EXPECTED_HASH"
			echo "Actual:   $ACTUAL_HASH"
			return 1
		fi
	else
		echo "Warning: No checksum file found at $CHECKSUM_FILE. Skipping verification."
	fi
}

mkdir -p "$ARTIFACT_DIR"
if [[ "$NAME" =~ "all" ]] ; then
	LIST=$(cat "$ARTIFACT_YSON" | yq 'keys' | awk -F ' ' '{print $2}')
	for i in $LIST ; do
		download $i
	done
	exit
fi
download $NAME
